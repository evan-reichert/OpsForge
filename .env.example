# ─── OpsForge — required environment variables ───────────────────────────────
# Copy this file to .env for local development and fill in real values.
# In production, set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your OpenAI secret key. The app falls back to heuristic analysis if unset.
OPENAI_API_KEY=

# Which model to use for CSV interpretation (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# ── Database ──────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection string for your PostgreSQL database.
# Required in production — the app will refuse to start without it.
# Recommended providers: Neon (neon.tech), Supabase, Railway, Vercel Postgres.
# Accepted formats:
#   postgresql+psycopg://user:password@host/dbname
#   postgres://user:password@host/dbname          (auto-normalised)
#   postgresql://user:password@host/dbname        (auto-normalised)
DATABASE_URI=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins that the API should accept requests from.
# Set this to your Vercel deployment URL in production, e.g.:
#   CORS_ALLOW_ORIGINS=https://opsforge.vercel.app
# Leave blank in local development — localhost is allowed automatically via regex.
CORS_ALLOW_ORIGINS=

# ── Abuse-prevention limits (optional overrides) ──────────────────────────────
# Maximum CSV file size in bytes (default: 10485760 = 10 MB).
MAX_UPLOAD_BYTES=10485760

# Maximum number of CSV rows accepted per upload (default: 5000).
MAX_CSV_ROWS=5000

# Rate limit applied per IP address on the /upload endpoint (default: 10/minute).
# Uses slowapi / limits syntax: "10/minute", "5/hour", etc.
UPLOAD_RATE_LIMIT=10/minute

# Shared bearer token required for protected API routes (/upload, /reports*).
# Frontend users enter this token on the auth screen before the app unlocks.
ACCESS_TOKEN=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Base URL the React app uses to reach the FastAPI backend.
# Local development: http://127.0.0.1:8000
# Vercel production: leave blank or set to your deployment URL (no trailing slash).
# When both apps are on the same Vercel deployment, you can omit this entirely —
# the frontend falls back to http://127.0.0.1:8000 in dev automatically.
VITE_API_BASE_URL=http://127.0.0.1:8000
